{
  "manifest_version": 3,
  "name": "Planerare OS - Bridge",
  "version": "1.3",
  "description": "Total integration mellan Planerare OS, fordonsregister och grossister.",
  "permissions": [
    "clipboardWrite",
    "storage"
  ],
  "host_permissions": [
    "*://*.car.info/*",
    "*://*.oljemagasinet.se/*",
    "*://*.trodo.se/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
